<?xml version="1.0" encoding="UTF-8" ?>
<UserControl
    x:Class="ZhuLong.App.Views.AnalysisPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
            <TextBlock FontWeight="SemiBold" FontSize="16" Text="归因分析" />
            <Button x:Name="RefreshBtn" Content="刷新归因" Click="OnRefreshClick" HorizontalAlignment="Left" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Foreground="Gray" Text="总交易数" />
                    <TextBlock x:Name="TotalTradesText" FontSize="20" FontWeight="SemiBold" Text="-" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Foreground="Gray" Text="胜率" />
                    <TextBlock x:Name="WinRateText" FontSize="20" FontWeight="SemiBold" Text="-" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Foreground="Gray" Text="平均盈亏%" />
                    <TextBlock x:Name="AvgPnlText" FontSize="20" FontWeight="SemiBold" Text="-" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Foreground="Gray" Text="Profit Factor" />
                    <TextBlock x:Name="ProfitFactorText" FontSize="20" FontWeight="SemiBold" Text="-" />
                </StackPanel>
            </Grid>

            <TextBlock FontWeight="SemiBold" Text="累计盈亏% 曲线" />
            <Border x:Name="PnlPlotHost" BorderBrush="Gray" BorderThickness="1" Height="240" />

            <TextBlock FontWeight="SemiBold" Text="置信度分箱（prob_threshold）" />
            <ListView x:Name="BinList" MinHeight="120" />

            <TextBlock FontWeight="SemiBold" Text="最近 30 笔交易" />
            <ListView x:Name="TradeList" MinHeight="200" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
