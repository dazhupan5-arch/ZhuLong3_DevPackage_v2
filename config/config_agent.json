      "knowledge_net": {
        "model_path": "models/knowledge_net_oil.onnx",
        "model_path_pytorch": "models/knowledge_net_oil.pth",
        "scaler_path": "models/knowledge_scaler_oil.pkl"
      },
      "rl": {
        "model_path": "models/rl_agent_oil"
